.DS_Store
__pycache__/
*.pyc
.pytest_cache/
.venv/

# Python package build artifacts (task-cli is a real package; pip/pipx build produces
# these from pyproject.toml — never commit them).
build/
dist/
*.egg-info/

# uv writes a lockfile when run via `uv run`; the dev/CI path is pip, so the lock is a
# local artifact — never commit it.
uv.lock

# Per-machine Claude Code harness overrides (shared settings.json IS committed).
.claude/settings.local.json
