#!/usr/bin/env python3
# Thin shim for the legacy symlink install path (install.sh symlinks this into a bin dir;
# the symlink must resolve back to the repo to find the tasklib package). pipx / package
# installs use [project.scripts] task = "tasklib.cli:main" and never run this file. Keep it
# MINIMAL: every line here runs before any check, with the user's rights, from a file a
# ~/.local/bin symlink points at.
import os
import sys

# Follow the symlink to the real repo root and add it to sys.path ONLY when the sibling
# package is actually present there. Never insert blindly and never the cwd: sys.path[0]
# precedes stdlib for pure-python modules, so a stray tasklib/ would otherwise shadow the
# real one (task runs in foreign repos it is creating tickets for).
_root = os.path.dirname(os.path.dirname(os.path.realpath(__file__)))
if os.path.isfile(os.path.join(_root, "tasklib", "__init__.py")):
    sys.path.insert(0, _root)

from tasklib.cli import main  # noqa: E402

raise SystemExit(main())
